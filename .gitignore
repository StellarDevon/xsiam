# ── External runtime dependencies (binaries only, not source) ────────────────
/third_party/

# ── Build artifacts inside agents / gateway ───────────────────────────────────
/agents/data_provider/build/
/gateway/build/
/gateway/build-wsl/

# ── Large mock data files (generated; use initdb scripts to regenerate) ───────
/initdb/mock/data/

# ── Node dependencies & locks ─────────────────────────────────────────────────
node_modules/
/web/node_modules/

# ── Frontend build output (rebuilt from web/src via pnpm build) ───────────────
/web/dist/
/xsiam/dist/

# ── Go build artifacts ────────────────────────────────────────────────────────
*.exe
*.exe~
/xsiam/*.exe
/xsiam/*.exe~

# ── etcd data ─────────────────────────────────────────────────────────────────
/xsiam/default.etcd/
default.etcd/

# ── Runtime logs & temp ───────────────────────────────────────────────────────
*.log
*.log~
xsiam_err.log
xsiam_err.txt
xsiam_out.txt
/xsiam/agent-sim.log
/xsiam/agent-sim.err

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Playwright runtime artifacts ──────────────────────────────────────────────
/web/playwright-report/
/web/test-results/
/web/tests/playwright/auth-state.json

# ── xsiam runtime output logs ─────────────────────────────────────────────────
/xsiam/xsiam-out.txt
/xsiam/xsiam-err.txt
