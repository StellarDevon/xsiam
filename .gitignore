# ── External runtime dependencies (binaries only, not source) ────────────────
/third_party/

# ── Build artifacts inside agents / gateway ───────────────────────────────────
/agents/data_provider/build/
/gateway/build/
/gateway/build-wsl/

# ── Large mock data files (generated; use initdb scripts to regenerate) ───────
/initdb/mock/data/

# ── Node dependencies & locks ─────────────────────────────────────────────────
node_modules/
/web/node_modules/

# ── Frontend build output (rebuilt from web/src via pnpm build) ───────────────
/web/dist/
/xsiam/dist/

# ── output/ — most content is generated/runtime, but launchers and config are committed ──
/output/bin/
/output/logs/
/output/data/
/output/screenshots/
# config.yaml, *.bat, README.md in output/ are intentionally committed

# ── Go build artifacts left in source tree (legacy; now go to output/bin/) ────
*.exe
*.exe~
/xsiam/*.exe
/xsiam/*.exe~

# ── etcd data ─────────────────────────────────────────────────────────────────
/xsiam/default.etcd/
default.etcd/

# ── Redis runtime data & legacy xdr/ dir ─────────────────────────────────────
# xdr/ is empty and pending deletion (locked by a process CWD); ignored here.
/xdr/
dump.rdb

# ── Runtime logs & temp (legacy locations; now in output/logs/) ───────────────
*.log
*.log~
*.txt.log
/xsiam/agent-sim.log
/xsiam/agent-sim.err
/xsiam/xsiam-out.txt
/xsiam/xsiam-err.txt
/web/dev.log

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── GeoIP databases (large binary files; download separately from MaxMind) ────
/third_party/geoip/*.mmdb

# ── Playwright runtime artifacts ──────────────────────────────────────────────
/web/playwright-report/
/web/test-results/
/web/tests/playwright/auth-state.json
